  User,
  Coffee,
  X,
  Plus,
  Gamepad2,
  LogOut,
  HardDrive,
  Cpu,
  Home,
  Edit3,
  Check,
  FolderOpen,
  Terminal,
  Trash2,
  ShieldAlert,
  ShieldCheck,
  ChevronRight,
  Globe,
